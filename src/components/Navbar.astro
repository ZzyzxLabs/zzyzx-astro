---
---

<nav
    id="main-navbar"
    class="fixed top-0 left-0 w-full z-[100] transition-transform duration-300"
>
    <div
        class="mx-auto max-w-7xl px-6 md:px-10 py-4 flex items-center justify-between backdrop-blur-xl bg-bg-base/60 border-b border-white/10"
    >
        <a href="#home" class="flex items-center gap-3 group">
            <img src="/zzyzx_white.png" alt="Zzyzx Labs" class="w-7 h-7" />
            <span
                class="font-display text-lg md:text-xl font-semibold text-white tracking-tight group-hover:text-primary transition-colors"
            >
                Zzyzx Labs
            </span>
        </a>

        <div class="hidden md:flex items-center gap-10">
            <a href="#home" class="nav-link">Home</a>
            <a href="#projects" class="nav-link">Projects</a>
            <a href="#about" class="nav-link">About</a>
            <a href="#members" class="nav-link">Members</a>
            <a href="mailto:contact@zzyzx.com" class="nav-cta">Contact</a>
        </div>

        <button
            id="nav-toggle"
            class="md:hidden flex flex-col gap-1.5 p-2 group"
            aria-label="Toggle navigation"
        >
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
        </button>
    </div>

    <div
        id="mobile-menu"
        class="hidden md:hidden backdrop-blur-xl bg-bg-base/90 border-b border-white/10"
    >
        <div class="flex flex-col items-center gap-6 py-10">
            <a href="#home" class="mobile-nav-link">Home</a>
            <a href="#projects" class="mobile-nav-link">Projects</a>
            <a href="#about" class="mobile-nav-link">About</a>
            <a href="#members" class="mobile-nav-link">Members</a>
            <a href="mailto:contact@zzyzx.com" class="nav-cta mt-2">Contact</a>
        </div>
    </div>
</nav>

<script>
    let lastScrollY = window.scrollY;
    let ticking = false;
    const navbar = document.getElementById("main-navbar");

    window.addEventListener("scroll", () => {
        if (!ticking) {
            window.requestAnimationFrame(() => {
                const y = window.scrollY;
                if (y > lastScrollY && y > 80) {
                    navbar?.classList.add("-translate-y-full");
                } else {
                    navbar?.classList.remove("-translate-y-full");
                }
                lastScrollY = y;
                ticking = false;
            });
            ticking = true;
        }
    });

    const toggle = document.getElementById("nav-toggle");
    const mobileMenu = document.getElementById("mobile-menu");

    toggle?.addEventListener("click", () => {
        mobileMenu?.classList.toggle("hidden");
    });

    mobileMenu?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
            mobileMenu?.classList.add("hidden");
        });
    });
</script>

<style>
    .nav-link {
        font-family: var(--font-sans);
        font-size: 0.78rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: rgba(232, 238, 248, 0.65);
        transition: color 0.2s;
        text-decoration: none;
    }
    .nav-link:hover {
        color: var(--color-primary);
    }

    .mobile-nav-link {
        font-family: var(--font-display);
        font-size: 1.5rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.9);
        transition: color 0.2s;
        text-decoration: none;
    }
    .mobile-nav-link:hover {
        color: var(--color-primary);
    }

    .nav-cta {
        font-size: 0.75rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        padding: 0.55rem 1.1rem;
        border-radius: 9999px;
        background: var(--color-primary);
        color: var(--color-bg-base);
        font-weight: 600;
        transition: transform 0.2s, box-shadow 0.2s;
        text-decoration: none;
    }
    .nav-cta:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 22px -8px rgba(var(--rgb-primary), 0.55);
    }

    .hamburger-line {
        display: block;
        width: 22px;
        height: 1.5px;
        background: rgba(255, 255, 255, 0.85);
        border-radius: 2px;
        transition: all 0.3s;
    }
    #nav-toggle:hover .hamburger-line {
        background: var(--color-primary);
    }
</style>
