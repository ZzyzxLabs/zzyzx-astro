---
const projects = [
  {
    name: "SeaWallet",
    blurb: "Store, inherit, and utilize your assets with the most intelligent smart-contract wallet on Sui.",
    cta: { label: "Launch App", href: "https://example.com" },
    image: "/loadingscreen.png",
  },
  {
    name: "Nereus",
    blurb: "Sharpen your predictions with LLMs running inside trustable execution environments.",
    cta: { label: "Explore", href: "https://www.trynereus.xyz/" },
    image: "/nereus.png",
  },
  {
    name: "BermuDAO",
    blurb: "Learn, connect, and collaborate with one of the most active Web3 developer communities.",
    cta: { label: "Explore", href: "https://example.com" },
    image: "/bermuBlackG.png",
  },
];
---

<section id="projects" class="px-6 py-24">
  <div class="max-w-md mx-auto">
    <span class="eyebrow mb-6" data-animate="fade-up">Section 02 · Acts</span>
    <h2 class="font-display text-4xl font-semibold text-white tracking-tight leading-tight mt-2" data-animate="fade-up" style="transition-delay: 100ms">
      To amplify the last frontier.
    </h2>
    <p class="mt-5 text-base text-text-muted leading-relaxed" data-animate="fade-up" style="transition-delay: 200ms">
      Zzyzx Labs makes the gears and the knowledge available to all.
    </p>
  </div>

  <div class="mt-14 space-y-6 max-w-md mx-auto">
    {
      projects.map((p, i) => (
        <article
          class="group relative overflow-hidden rounded-2xl border border-white/10 bg-bg-card"
          data-animate="fade-up"
          style={`transition-delay: ${i * 80}ms`}
        >
          <div class="relative h-56 overflow-hidden">
            <img
              src={p.image}
              alt={p.name}
              class="absolute inset-0 w-full h-full object-cover opacity-90"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-bg-card via-bg-card/30 to-transparent" />
            <div class="absolute top-4 left-5 text-text-faint text-[10px] uppercase tracking-[0.3em] tabular-nums">
              0{i + 1}
            </div>
          </div>
          <div class="p-6 space-y-4">
            <h3 class="font-display text-2xl font-semibold text-white tracking-tight">
              {p.name === "BermuDAO" ? (
                <>Bermu<span class="text-primary">DAO</span></>
              ) : (
                p.name
              )}
            </h3>
            <p class="text-sm text-text-muted leading-relaxed">{p.blurb}</p>
            <a
              href={p.cta.href}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.2em] text-primary font-semibold pt-1"
            >
              {p.cta.label}
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </article>
      ))
    }
  </div>
</section>
