---
---
<section id="projects" class="py-20 space-y-12">
  <div class="px-6 text-center space-y-6">
     <h2 class="text-6xl font-bold text-white tracking-widest">ACTS</h2>
     <p class="text-xl text-gray-400 font-mono">To amplify the last of the planet,<br/>Zzyzx Labs makes the gears and knowledge available to all.</p>
  </div>

  <!-- Horizontal Scroll Container -->
  <!-- -mx-0 to ensure edge-to-edge scrolling on mobile if parent has padding, but here section has no x-padding on the container itself, only children -->
  <div class="flex overflow-x-auto snap-x snap-mandatory gap-6 px-6 pb-8 scrollbar-hide">
    
    <!-- Project 1: SeaWallet -->
    <div class="snap-center shrink-0 w-[85vw] flex flex-col gap-4 bg-white/5 rounded-3xl overflow-hidden border border-white/10">
      <div class="h-64 w-full overflow-hidden">
         <img src="/loadingscreen.png" alt="SeaWallet" class="w-full h-full object-cover" />
      </div>
      <div class="p-8 space-y-4 flex flex-col grow">
         <h3 class="text-3xl font-bold text-white">SeaWallet</h3>
         <p class="text-gray-300 grow">Store, inherit, utilize your asset with the most intelligent smart contract wallet on Sui network.</p>
         <a href="https://example.com" class="self-start inline-block px-6 py-3 bg-white text-black font-semibold rounded-lg mt-4">Launch App</a>
      </div>
    </div>

    <!-- Project 2: Nereus -->
    <div class="snap-center shrink-0 w-[85vw] flex flex-col gap-4 bg-white/5 rounded-3xl overflow-hidden border border-white/10">
      <div class="h-64 w-full overflow-hidden relative bg-black">
         <img src="/nereus.png" alt="Nereus" class="w-full h-full object-cover opacity-90" />
      </div>
      <div class="p-8 space-y-4 flex flex-col grow">
         <h3 class="text-3xl font-bold text-white font-serif">Nereus</h3>
         <p class="text-gray-300 grow">Enhance your predictions with the power of LLMs in trustable execution environments.</p>
         <a href="https://www.trynereus.xyz/" class="self-start inline-block px-6 py-3 bg-[#ff9f1c] text-[#050a14] font-semibold rounded-lg mt-4">Explore Now</a>
      </div>
    </div>

    <!-- Project 3: BermuDAO -->
    <div class="snap-center shrink-0 w-[85vw] flex flex-col gap-4 bg-white/5 rounded-3xl overflow-hidden border border-white/10">
      <div class="h-64 w-full overflow-hidden bg-slate-950">
         <img src="/bermuBlackG.png" alt="BermuDAO" class="w-full h-full object-cover opacity-90" />
      </div>
      <div class="p-8 space-y-4 flex flex-col grow">
         <h3 class="text-3xl font-bold text-white tracking-wider">Bermu<span class="text-cyan-500">DAO</span></h3>
         <p class="text-gray-300 grow">Learn, Connect, Collaborate with the most vibrant community of Web3 developers.</p>
         <a href="https://example.com" class="self-start inline-block px-6 py-3 bg-cyan-600 text-white font-medium rounded-lg mt-4">Explore Now</a>
      </div>
    </div>
  </div>
</section>

<style>
  /* Hide scrollbar for Chrome, Safari and Opera */
  .scrollbar-hide::-webkit-scrollbar {
      display: none;
  }
  /* Hide scrollbar for IE, Edge and Firefox */
  .scrollbar-hide {
      -ms-overflow-style: none;  /* IE and Edge */
      scrollbar-width: none;  /* Firefox */
  }
</style>
