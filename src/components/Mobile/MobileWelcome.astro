---
import SuperCarHero from "../SuperCarHero.astro";
import Page1 from "../Pages/page1.astro";
import About from "../About.astro";
import MobileProjects from "./MobileProjects.astro";
import MobileMembers from "./MobileMembers.astro";
---

<!-- Fixed video hero (mobile keeps SuperCar only — Mars Globe is too heavy on phones) -->
<SuperCarHero />

<div class="relative w-full overflow-x-hidden">
  <!-- Hero on transparent background to show the video through -->
  <div class="relative z-10 w-full">
    <Page1 />
  </div>

  <!-- Solid sections cover the video as we scroll -->
  <div class="relative z-20 bg-bg-base">
    <MobileProjects />
    <div class="hairline"></div>
    <div id="about">
      <About />
    </div>
    <div class="hairline"></div>
    <MobileMembers />
  </div>
</div>
