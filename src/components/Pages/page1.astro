---
---

<section
    id="home"
    class="relative w-full min-h-screen flex items-center justify-center px-5 sm:px-6 py-24 sm:py-32"
>
    <div class="relative z-10 max-w-5xl w-full text-center flex flex-col items-center">
        <span class="eyebrow mb-8 opacity-0 animate-rise" style="animation-delay: 0.05s">
            Zzyzx Labs · Est. 2024
        </span>

        <h1
            class="font-display font-semibold text-white leading-[0.95] tracking-tight opacity-0 animate-rise hero-title"
            style="animation-delay: 0.15s"
        >
            Building at the
            <span class="block text-primary">last frontier.</span>
        </h1>

        <p
            class="mt-8 sm:mt-10 max-w-2xl text-base sm:text-lg md:text-xl text-text-muted leading-relaxed opacity-0 animate-rise hero-sub"
            style="animation-delay: 0.35s"
        >
            A small studio shipping Web3 infrastructure and AI-native products
            on Sui — and the open tools that come with them.
        </p>

        <div
            class="mt-10 sm:mt-12 flex flex-col sm:flex-row flex-wrap items-stretch sm:items-center justify-center gap-3 sm:gap-4 w-full sm:w-auto opacity-0 animate-rise"
            style="animation-delay: 0.5s"
        >
            <a href="#projects" class="btn-primary">View Projects</a>
            <a href="#about" class="btn-ghost">About the Lab</a>
        </div>
    </div>

    <!-- Scroll cue -->
    <div
        class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-text-faint opacity-0 animate-rise"
        style="animation-delay: 0.8s"
    >
        <span class="text-[10px] tracking-[0.3em] uppercase">Scroll</span>
        <span class="block w-px h-10 bg-gradient-to-b from-text-faint to-transparent"></span>
    </div>
</section>

<style>
    @keyframes rise {
        from {
            opacity: 0;
            transform: translateY(16px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .animate-rise {
        animation: rise 0.9s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
    }

    .hero-title {
        font-size: clamp(2.5rem, 11vw, 9rem);
        text-shadow:
            0 2px 24px rgba(0, 0, 0, 0.6),
            0 0 80px rgba(0, 0, 0, 0.4);
    }
    .hero-sub {
        text-shadow: 0 1px 12px rgba(0, 0, 0, 0.7);
    }

    .btn-primary {
        font-size: 0.8rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        padding: 0.95rem 1.6rem;
        border-radius: 9999px;
        background: var(--color-primary);
        color: var(--color-bg-base);
        font-weight: 600;
        text-align: center;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        text-decoration: none;
    }
    .btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: 0 12px 30px -8px rgba(var(--rgb-primary), 0.55);
    }

    .btn-ghost {
        font-size: 0.8rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        padding: 0.9rem 1.55rem;
        border-radius: 9999px;
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: rgba(255, 255, 255, 0.85);
        font-weight: 500;
        text-align: center;
        transition: border-color 0.25s ease, color 0.25s ease;
        text-decoration: none;
    }
    .btn-ghost:hover {
        border-color: rgba(var(--rgb-primary), 0.6);
        color: var(--color-primary);
    }
</style>
