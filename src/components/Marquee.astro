---
interface Props {
    direction?: "left" | "right";
    speed?: number;
}

const { direction = "left", speed = 45 } = Astro.props;

const keywords = [
    "Sui",
    "Web3",
    "AI Agents",
    "Smart Contracts",
    "Cryptography",
    "Open Source",
    "Infrastructure",
    "Applied Research",
];
---

<div class="marquee-container relative overflow-hidden py-10 select-none">
    <div
        class:list={[
            "marquee-track flex whitespace-nowrap items-center",
            direction === "right" ? "marquee-reverse" : "marquee-forward",
        ]}
        style={`--marquee-speed: ${speed}s`}
    >
        {
            [...Array(4)].map(() => (
                <div class="flex items-center shrink-0">
                    {keywords.map((word) => (
                        <span class="font-display text-2xl md:text-4xl font-light text-text-faint tracking-tight px-8 flex items-center gap-8">
                            {word}
                            <span class="text-text-faint/40">/</span>
                        </span>
                    ))}
                </div>
            ))
        }
    </div>
</div>

<style>
    .marquee-container {
        mask-image: linear-gradient(
            to right,
            transparent,
            black 8%,
            black 92%,
            transparent
        );
    }

    .marquee-forward {
        animation: marquee-scroll var(--marquee-speed) linear infinite;
    }
    .marquee-reverse {
        animation: marquee-scroll-reverse var(--marquee-speed) linear infinite;
    }

    @keyframes marquee-scroll {
        from { transform: translateX(0); }
        to { transform: translateX(-25%); }
    }
    @keyframes marquee-scroll-reverse {
        from { transform: translateX(-25%); }
        to { transform: translateX(0); }
    }
</style>
