---
const services = [
    {
        title: "Website Design",
        body: "Custom marketing sites, dApp front-ends, and interactive product surfaces.",
    },
    {
        title: "Project Commission",
        body: "End-to-end builds — smart contracts, infra, and product engineering on Sui.",
    },
    {
        title: "Applied Research",
        body: "Cryptography, agent systems, and protocol-level work for partners and our own products.",
    },
];

const stats = [
    { value: "6×", label: "Hackathon Wins" },
    { value: "$26K+", label: "Prize Money" },
    { value: "5+", label: "Products Shipped" },
    { value: "250+", label: "Community" },
];
---

<section
    id="about"
    class="relative w-full px-5 sm:px-6 py-24 md:py-40 overflow-hidden"
>
    <!-- Subtle background accent -->
    <div
        class="pointer-events-none absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[600px] rounded-full bg-primary/[0.05] blur-[140px]"
    >
    </div>

    <div class="relative max-w-6xl mx-auto">
        <!-- Section header -->
        <div class="max-w-3xl" data-animate="fade-up">
            <span class="eyebrow mb-6">About the Lab</span>
            <h2
                class="font-display text-[clamp(2rem,7vw,3.75rem)] font-semibold text-white leading-[1.05] tracking-tight"
            >
                A small studio building
                <span class="text-primary">high-leverage</span>
                products on Sui.
            </h2>
            <p class="mt-6 sm:mt-8 text-base sm:text-lg md:text-xl text-text-muted leading-relaxed max-w-2xl">
                We pair Web3 infrastructure with AI tooling and ship them as
                products, libraries, and the occasional protocol. Open source
                where it makes sense, secure by default, and built to scale.
            </p>
        </div>

        <!-- Mission / Vision split -->
        <div class="mt-20 grid grid-cols-1 md:grid-cols-2 gap-px bg-white/10 border border-white/10 rounded-2xl overflow-hidden" data-animate="fade-up">
            <div class="bg-bg-base p-8 md:p-10">
                <div class="text-text-faint text-xs uppercase tracking-[0.3em] mb-4">
                    Mission
                </div>
                <p class="text-lg text-white/85 leading-relaxed">
                    Build next-generation Web3 infrastructure and AI-powered
                    tools — empowering builders and users with secure, scalable
                    solutions.
                </p>
            </div>
            <div class="bg-bg-base p-8 md:p-10">
                <div class="text-text-faint text-xs uppercase tracking-[0.3em] mb-4">
                    Vision
                </div>
                <p class="text-lg text-white/85 leading-relaxed">
                    Pioneer the convergence of AI and blockchain to push the
                    boundaries of what's possible in decentralized technology.
                </p>
            </div>
        </div>

        <!-- Services -->
        <div class="mt-24">
            <span class="eyebrow mb-6" data-animate="fade-up">What we do</span>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mt-6">
                {
                    services.map((s, i) => (
                        <div class="group relative pt-8 border-t border-white/10" data-animate="fade-up" style={`transition-delay: ${i * 80}ms`}>
                            <div class="absolute top-0 left-0 h-px w-12 bg-primary opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
                            <div class="font-display text-text-faint text-sm tabular-nums mb-3">
                                0{i + 1}
                            </div>
                            <h3 class="font-display text-2xl text-white font-medium mb-3">
                                {s.title}
                            </h3>
                            <p class="text-text-muted leading-relaxed text-base">
                                {s.body}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>

        <!-- Stats strip -->
        <div class="mt-24 grid grid-cols-2 md:grid-cols-4 gap-8 border-t border-white/10 pt-12">
            {
                stats.map((s, i) => (
                    <div data-animate="fade-up" style={`transition-delay: ${i * 60}ms`}>
                        <div class="font-display text-3xl sm:text-4xl md:text-5xl font-semibold text-white">
                            {s.value}
                        </div>
                        <div class="text-text-faint text-[10px] sm:text-xs uppercase tracking-[0.25em] mt-2">
                            {s.label}
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
